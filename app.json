{
  "expo": {
    "name": "Rwendo",
    "slug": "rwendo",
    "version": "1.0.0",
    "scheme": "rwendo",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3C6E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rwendo.rwendo",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Rwendo uses the microphone for voice conversations with Rwen and for pronunciation practice.",
        "NSCameraUsageDescription": "Rwendo uses the camera so you can set a profile picture.",
        "NSPhotoLibraryUsageDescription": "Rwendo uses your photo library so you can choose a profile picture.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "app.rwendo.rwendo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH_CONNECT",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-asset",
      "expo-dev-client",
      [
        "react-native-purchases",
        { "ios": { "useFrameworks": "static" } }
      ]
    ],
    "assetBundlePatterns": [
      "assets/**"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c798bcf3-9999-4874-b60c-75b5598c4674"
      }
    },
    "owner": "vibe1ai"
  }
}
