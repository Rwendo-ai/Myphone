# Copy this to worker/.env and fill in the values.

# ─── Daily.co (WebRTC transport, free tier) ───────────────────────────────
# Sign up at https://dashboard.daily.co → Developers → API keys
DAILY_API_KEY=your_daily_key_here
DAILY_DOMAIN=your-rwendo-subdomain   # the .daily.co subdomain (without protocol)

# ─── Anthropic (Claude LLM — the brain) ───────────────────────────────────
ANTHROPIC_API_KEY=...
# Claude model the worker uses. Haiku is cheap and fast for the
# voice path; switch to sonnet for text chat that needs more depth.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── ElevenLabs (TTS only — voice playback) ───────────────────────────────
ELEVENLABS_API_KEY=...
# Default voice if a companion has no voice_id set.
ELEVENLABS_DEFAULT_VOICE_ID=...

# ─── Deepgram (STT — speech to text) ──────────────────────────────────────
# Free tier covers our scale comfortably.
DEEPGRAM_API_KEY=...

# ─── Simli (lipsync avatar — premium tier only) ───────────────────────────
SIMLI_API_KEY=...

# ─── Supabase (companion config + transcript persistence) ─────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Bot worker config ────────────────────────────────────────────────────
# Port the bot HTTP endpoint listens on (Edge Function POSTs here to
# spawn a session bot for a specific Daily room).
BOT_PORT=7860
# Public URL of the bot server (so the Edge Function can reach it).
# In dev with `cloudflared` or `ngrok`, set this to the tunnel URL.
BOT_PUBLIC_URL=http://localhost:7860
