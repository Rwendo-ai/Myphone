# Copy to .env.local and fill in.
# Production: set these in Vercel Project Settings → Environment Variables.

# Supabase — same project as the mobile app
NEXT_PUBLIC_SUPABASE_URL=https://jkjznverqjaokmtvbpqv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — used ONLY by /api/stripe-webhook to grant tokens via SECURITY DEFINER RPCs.
# NEVER expose to the browser. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL used for Stripe success/cancel redirects + OAuth callback.
# Local dev: http://localhost:3000
# Production: https://rwendo.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
